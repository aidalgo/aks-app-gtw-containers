location    = "eastus2"
name_prefix = "agc-byo"

# Optional overrides (all have sensible defaults):
# system_node_count         = 1
# node_vm_size              = "Standard_D2s_v5"
# vnet_address_space        = ["10.0.0.0/8"]
# aks_subnet_address_prefix = "10.240.0.0/16"
# agc_subnet_address_prefix = "10.241.0.0/24"

# Restrict AGC frontend access to known IP ranges (CIDR notation).
# AGC frontends are always public; this WAF rule blocks all other sources.
# Leave empty or omit to allow all traffic.
# allowed_source_ranges = ["203.0.113.0/24", "198.51.100.0/24"]
